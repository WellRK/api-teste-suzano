{
  "name": "ovgs-api",
  "version": "0.0.1",
  "description": "Sistema de Gestão de Ordens de Venda (OVGS) - API REST",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "ts-node src/main.ts",
    "start:dev": "yarn && cross-env NODE_ENV=dev nest start --watch",
    "start:hom": "yarn && cross-env NODE_ENV=hom nest start --watch",
    "start:prod": "cross-env NODE_ENV=prod node build/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "publish:dev": "yarn && yarn build && bash ./config/pm2/dev.script.sh",
    "publish:hom": "yarn && yarn build && bash ./config/pm2/hom.script.sh",
    "publish:prod": "yarn && yarn build && bash ./config/pm2/prod.script.sh",
    "typeorm:dev": "cross-env NODE_ENV=dev npx typeorm-ts-node-commonjs -d ./src/modules/_database/config/database-migrations.config.ts",
    "typeorm:hom": "cross-env NODE_ENV=hom npx typeorm-ts-node-commonjs -d ./src/modules/_database/config/database-migrations.config.ts",
    "typeorm:prod": "cross-env NODE_ENV=prod npx typeorm-ts-node-commonjs -d ./src/modules/_database/config/database-migrations.config.ts",
    "migration:generate:dev": "yarn typeorm:dev migration:generate ./src/modules/_database/migrations/migration -t",
    "migration:run:dev": "yarn typeorm:dev migration:run",
    "migration:run:hom": "yarn typeorm:hom migration:run",
    "migration:run:prod": "yarn typeorm:prod migration:run",
    "migration:revert:dev": "yarn typeorm:dev migration:revert",
    "migration:revert:hom": "yarn typeorm:hom migration:revert",
    "migration:revert:prod": "yarn typeorm:prod migration:revert",
    "seed:dev": "cross-env NODE_ENV=dev npx nestjs-command seed:database",
    "seed:hom": "cross-env NODE_ENV=hom npx nestjs-command seed:database",
    "seed:prod": "cross-env NODE_ENV=prod npx nestjs-command seed:database"
  },
  "dependencies": {
    "@nestjs/axios": "^0.1.0",
    "@nestjs/common": "^8.0.0",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "^8.0.0",
    "@nestjs/event-emitter": "^1.4.2",
    "@nestjs/jwt": "^9.0.0",
    "@nestjs/passport": "^9.0.0",
    "@nestjs/platform-express": "^8.0.0",
    "@nestjs/swagger": "^6.1.2",
    "@nestjs/terminus": "^8.1.0",
    "@nestjs/typeorm": "^9.0.1",
    "@ntegral/nestjs-sendgrid": "^1.0.0",
    "@zenvia/sdk": "^2.4.4",
    "aws-sdk": "^2.1238.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.1",
    "cache-manager": "^3.6.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "fs": "^0.0.1-security",
    "geolib": "^3.3.3",
    "i": "^0.3.7",
    "install": "^0.13.0",
    "js2xmlparser": "^5.0.0",
    "mysql2": "^2.3.3",
    "nestjs-command": "^3.1.2",
    "node-geocoder": "^4.2.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.4.0",
    "prom-client": "^14.2.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "swagger-ui-express": "^4.5.0",
    "typeorm": "0.3.10",
    "utility-types": "^3.10.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.4.23",
    "xmlbuilder": "^15.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^8.0.0",
    "@nestjs/schematics": "^8.0.0",
    "@nestjs/testing": "^8.0.0",
    "@types/cache-manager": "^3.4.3",
    "@types/express": "^4.17.16",
    "@types/express-serve-static-core": "^4.17.33",
    "@types/jest": "27.5.0",
    "@types/multer": "^1.4.7",
    "@types/node": "20.14.0",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^29.7.0",
    "prettier": "^2.3.2",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "28.0.1",
    "ts-loader": "^9.2.3",
    "ts-node": "10.7.0",
    "tsconfig-paths": "4.0.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "**/order-state-machine.ts": {
        "statements": 95,
        "branches": 70,
        "functions": 100,
        "lines": 95
      },
      "**/ordem-venda.service.ts": {
        "statements": 90,
        "branches": 78,
        "functions": 80,
        "lines": 90
      },
      "**/agendamento.service.ts": {
        "statements": 90,
        "branches": 70,
        "functions": 100,
        "lines": 95
      }
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
